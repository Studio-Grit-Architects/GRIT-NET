# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NextAuth — generate a random secret: run `openssl rand -base64 32` in terminal
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — get these from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin email — only this email can manage projects and team (server-side only — do NOT use NEXT_PUBLIC_ prefix)
ADMIN_EMAIL=ernest@yourdomain.com

# Test/demo mode — set to true on the test deployment only.
# When enabled, any signed-in user is treated as admin (no domain or DB check).
# Leave unset or set to false on the production site.
DEMO_MODE=false

# Anthropic — used for the studio chat assistant
ANTHROPIC_API_KEY=your_anthropic_api_key

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# AI / Transcription
CRON_SECRET=
GROQ_API_KEY=
GEMINI_API_KEY=

# Gmail integration
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
