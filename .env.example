# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable: Google Calendar API, Gmail API
# OAuth scopes: openid, email, profile, gmail.readonly, calendar.readonly
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Supabase ───────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Access control ─────────────────────────────────────────────────────────────
# Only email addresses ending in this domain can sign in.
# Leave blank to allow any Google account.
ALLOWED_EMAIL_DOMAIN=yourstudio.com

# First sign-in from this address gets admin privileges automatically.
ADMIN_EMAIL=admin@yourstudio.com

# ── Firm details ───────────────────────────────────────────────────────────────
# Shown in the app header, login page, and AI assistant
NEXT_PUBLIC_FIRM_NAME=Your Studio Name

# ── AI features (optional — app works without these) ──────────────────────────
# Studio chat, meeting summaries, email digest
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Meeting transcription (~$0.26/hr, $200 free credit)
# Get a key at https://deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key
